rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Helpers
    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation Blueprint for Singer
    function isValidSinger(data) {
      return data.username is string && data.username.size() <= 64 && data.username.matches('^[a-zA-Z0-9_\\-]+$')
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.phone is string && data.phone.size() >= 5 && data.phone.size() <= 30
        && data.email is string && data.email.size() >= 5 && data.email.size() <= 100
        && data.slogan is string && data.slogan.size() <= 200
        && data.bio is string && data.bio.size() <= 2000
        && data.genre is string && data.genre.size() <= 100
        && data.themeColor is string && data.themeColor.size() <= 20;
    }

    // singers collection match block
    match /singers/{username} {
      allow get: if isValidId(username);
      allow list: if true;
      allow create: if isValidId(username) 
        && isValidSinger(request.resource.data) 
        && request.resource.data.username == username;
      allow update: if isValidId(username) 
        && isValidSinger(request.resource.data) 
        && request.resource.data.username == username;
      allow delete: if isValidId(username);
    }

    // 1. Default-deny catch-all (placed at the bottom to prevent interference)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
